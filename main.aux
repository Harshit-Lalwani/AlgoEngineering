\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces MSD Radix Sort: mean recursion depth vs.\ time per character ($\mu $s/char). Each line represents a dataset across different $N$ values. The positive correlation confirms depth drives cost.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:depth}{{5}{10}{MSD Radix Sort: mean recursion depth vs.\ time per character ($\mu $s/char). Each line represents a dataset across different $N$ values. The positive correlation confirms depth drives cost}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces LLC misses per element across algorithms for a fixed problem size ($N=10^4$). MSD Radix Sort and C-Burstsort show differing cache behaviours.}}{11}{figure.6}\protected@file@percent }
\newlabel{fig:llc}{{6}{11}{LLC misses per element across algorithms for a fixed problem size ($N=10^4$). MSD Radix Sort and C-Burstsort show differing cache behaviours}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces LLC miss rate vs.\ $N$ for \texttt  {std::sort} vs.\ C-Burstsort on \texttt  {wiki\_random}. The cache-aware design keeps miss rates flat while the cache-agnostic baseline degrades as $N$ exceeds LLC capacity. This directly confirms the near-$O(N/B)$ I/O behaviour of C-Burstsort.}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:llc_two}{{7}{12}{LLC miss rate vs.\ $N$ for \texttt {std::sort} vs.\ C-Burstsort on \texttt {wiki\_random}. The cache-aware design keeps miss rates flat while the cache-agnostic baseline degrades as $N$ exceeds LLC capacity. This directly confirms the near-$O(N/B)$ I/O behaviour of C-Burstsort}{figure.7}{}}
