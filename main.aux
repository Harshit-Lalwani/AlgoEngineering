\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Mean execution time at largest $N$ (error bars: $\pm 1\sigma $, 10 seeds) for all four datasets. C-Burstsort is the fastest or joint-fastest on all wiki datasets; on \texttt  {random}, Burstsort and C-Burstsort are comparable. MSD Radix Sort is the clear outlier on prefix-heavy and wiki-heavy inputs.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:best}{{3}{8}{Mean execution time at largest $N$ (error bars: $\pm 1\sigma $, 10 seeds) for all four datasets. C-Burstsort is the fastest or joint-fastest on all wiki datasets; on \texttt {random}, Burstsort and C-Burstsort are comparable. MSD Radix Sort is the clear outlier on prefix-heavy and wiki-heavy inputs}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Time per character ($\mu $s/char) at $N = 10^6$ for each algorithm across all four datasets. Burstsort-family algorithms show low and consistent cost across datasets. MSD Radix Sort has the highest per-character cost on \texttt  {prefix\_heavy} and \texttt  {wiki\_heavy}, confirming that depth-driven recursion is the bottleneck.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:tpc}{{4}{9}{Time per character ($\mu $s/char) at $N = 10^6$ for each algorithm across all four datasets. Burstsort-family algorithms show low and consistent cost across datasets. MSD Radix Sort has the highest per-character cost on \texttt {prefix\_heavy} and \texttt {wiki\_heavy}, confirming that depth-driven recursion is the bottleneck}{figure.4}{}}
