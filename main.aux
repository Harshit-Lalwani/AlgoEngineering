\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Execution time vs.\ $N$ (log-$x$ scale) on the \texttt  {random} dataset (mean $\pm 1\sigma $, 10 seeds). Burstsort and C-Burstsort exhibit near-linear scaling; \texttt  {std::sort} curves upward as $N$ outgrows the LLC.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:time_random}{{1}{6}{Execution time vs.\ $N$ (log-$x$ scale) on the \texttt {random} dataset (mean $\pm 1\sigma $, 10 seeds). Burstsort and C-Burstsort exhibit near-linear scaling; \texttt {std::sort} curves upward as $N$ outgrows the LLC}{figure.1}{}}
